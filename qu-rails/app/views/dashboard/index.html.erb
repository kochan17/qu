<%# Today ダッシュボード — Apple News+ × Fitness の引き算デザイン。
    Daily Ring と今日のキューのみ。煽り・断言形は使わない。 %>
<% content_for :title, "Today" %>

<%
  recall_pct = @activity.recall_goal.positive? ?
    [ (@activity.recall_count.to_f / @activity.recall_goal * 100).round, 100 ].min : 0
  learn_pct = @activity.learn_goal.positive? ?
    [ (@activity.learn_count.to_f / @activity.learn_goal * 100).round, 100 ].min : 0
  queue_total = @due_count + @new_count
%>

<div class="mx-auto max-w-2xl space-y-8">

  <%# ── 日付 + 控えめなストリーク ───────────────────────────── %>
  <header class="flex items-baseline justify-between">
    <div>
      <p class="text-sm text-content-faint"><%= japanese_date(Date.current) %></p>
      <h1 class="mt-1 text-2xl font-semibold tracking-tight text-content">今日の学習</h1>
    </div>
    <%# 継続中はストリークを大きく見せない（Phase 1 仕様 / Calm Mode 中は隠す）%>
    <% if Current.user.current_streak.positive? && !Current.user.calm_mode_active? %>
      <div class="text-right">
        <p class="text-xs text-content-faint">継続</p>
        <p class="text-sm font-medium text-content-muted"><%= Current.user.current_streak %> 日</p>
      </div>
    <% end %>
  </header>

  <%# ── Daily Ring ────────────────────────────────────────── %>
  <section class="rounded-3xl border border-border-subtle bg-surface-elevated p-6 sm:p-8">
    <div class="flex flex-col items-center gap-7 sm:flex-row sm:gap-9">
      <%= render "shared/daily_ring", activity: @activity %>

      <div class="w-full space-y-4">
        <p class="text-sm font-medium text-content">今日の進捗</p>

        <div class="space-y-1.5">
          <div class="flex justify-between text-xs text-content-muted">
            <span>復習</span>
            <span class="tabular-nums"><%= @activity.recall_count %> / <%= @activity.recall_goal %></span>
          </div>
          <div class="h-1.5 overflow-hidden rounded-full bg-surface-sunken">
            <div class="h-full rounded-full bg-tint transition-all duration-700"
                 style="width: <%= recall_pct %>%"></div>
          </div>
        </div>

        <div class="space-y-1.5">
          <div class="flex justify-between text-xs text-content-muted">
            <span>新規学習</span>
            <span class="tabular-nums"><%= @activity.learn_count %> / <%= @activity.learn_goal %></span>
          </div>
          <div class="h-1.5 overflow-hidden rounded-full bg-surface-sunken">
            <div class="h-full rounded-full bg-tint/60 transition-all duration-700"
                 style="width: <%= learn_pct %>%"></div>
          </div>
        </div>

        <p class="text-sm <%= @activity.core_completed? ? "text-tint" : "text-content-faint" %>">
          <% if @activity.core_completed? %>
            今日の目標に届きました。
          <% elsif @activity.core_done.positive? %>
            あと <%= @activity.core_goal - @activity.core_done %> 問で今日の目標です。
          <% else %>
            今日の <%= @activity.core_goal %> 問を始めましょう。
          <% end %>
        </p>
      </div>
    </div>
  </section>

  <%# ── 今日のキュー / CTA ───────────────────────────────────── %>
  <section>
    <% if @certification.nil? %>
      <div class="rounded-2xl border border-border-subtle bg-surface-elevated px-6 py-10 text-center">
        <p class="text-sm text-content-muted">学習する資格を設定すると、今日のキューが届きます。</p>
        <%= link_to "資格を選ぶ", settings_path,
              class: "mt-4 inline-block rounded-xl bg-tint px-5 py-2.5 text-sm font-medium text-on-tint" %>
      </div>

    <% elsif @activity.core_completed? %>
      <div class="rounded-2xl border border-border-subtle bg-surface-elevated px-6 py-8 text-center">
        <%= icon("check_circle", filled: true, css: "text-3xl text-tint") %>
        <p class="mt-2 text-sm font-medium text-content">今日の目標を達成しました</p>
        <p class="mt-1 text-sm text-content-faint">ここまでよく続けています。</p>
        <div class="mt-5 flex flex-col gap-2 sm:flex-row sm:justify-center">
          <%= link_to "さらに演習を続ける", practice_path,
                class: "rounded-xl border border-border-subtle px-5 py-2.5 text-sm font-medium text-content transition-colors hover:bg-surface-sunken" %>
          <%= link_to "新しい単元を学ぶ", courses_path,
                class: "rounded-xl border border-border-subtle px-5 py-2.5 text-sm font-medium text-content transition-colors hover:bg-surface-sunken" %>
        </div>
      </div>

    <% elsif queue_total.positive? %>
      <h2 class="mb-3 text-base font-semibold text-content">今日のキュー</h2>
      <%= link_to practice_path,
            class: "group flex items-center justify-between rounded-2xl border border-border-subtle bg-surface-elevated px-6 py-5 transition-colors hover:bg-surface-sunken" do %>
        <div>
          <p class="text-sm font-medium text-content">演習を始める</p>
          <p class="mt-0.5 text-sm text-content-faint">
            <% parts = [] %>
            <% parts << "復習 #{@due_count} 問" if @due_count.positive? %>
            <% parts << "新規 #{@new_count} 問" if @new_count.positive? %>
            <%= parts.join("・") %>
          </p>
        </div>
        <%= icon("arrow_forward", css: "text-xl text-content-faint transition-transform group-hover:translate-x-0.5") %>
      <% end %>

    <% else %>
      <div class="rounded-2xl border border-border-subtle bg-surface-elevated px-6 py-10 text-center">
        <p class="text-sm text-content-muted">今日のキューは空です。新しい単元を学んでみましょう。</p>
        <%= link_to "学習を続ける", courses_path,
              class: "mt-4 inline-block rounded-xl bg-tint px-5 py-2.5 text-sm font-medium text-on-tint" %>
      </div>
    <% end %>
  </section>

</div>
