<%# 設定画面 — セクションを .card で束ね、行単位で並べる。 %>
<% content_for :title, "設定" %>

<div class="mx-auto max-w-3xl px-4 py-10 md:px-0 md:py-14 space-y-8">

  <header class="mb-2">
    <h1 class="text-headline-lg font-headline font-semibold text-on-surface">設定</h1>
  </header>

  <%= form_with model: @user, url: settings_path, method: :patch, class: "space-y-8" do |f| %>

    <%# 1. プロフィール %>
    <section>
      <h2 class="mb-2 text-label-caps font-label font-semibold uppercase tracking-widest text-on-surface-variant">プロフィール</h2>
      <div class="card divide-y divide-outline-variant overflow-hidden">
        <div class="flex items-center gap-4 px-5 py-4">
          <%= f.label :display_name, class: "w-24 shrink-0 text-sm font-medium text-on-surface font-body" do %>
            表示名
          <% end %>
          <%= f.text_field :display_name,
                placeholder: "名前を入力",
                class: "min-w-0 flex-1 bg-transparent text-sm text-on-surface placeholder:text-outline focus:outline-none font-body" %>
        </div>
      </div>
    </section>

    <%# 2. 学習する資格 %>
    <section>
      <h2 class="mb-2 text-label-caps font-label font-semibold uppercase tracking-widest text-on-surface-variant">学習する資格</h2>
      <div class="card divide-y divide-outline-variant overflow-hidden">
        <% @certifications.each do |cert| %>
          <%# 選択中は bg-primary-container で明示。ラジオボタン実体を維持しつつ行全体をラベルで包む。 %>
          <%# has-[:checked] で行全体の背景・テキスト・ラジオ表示を制御する %>
          <label class="flex cursor-pointer items-center justify-between gap-4 px-5 py-4 transition-colors
                        has-[:checked]:bg-primary-fixed hover:bg-surface-container">
            <div class="flex items-center gap-3">
              <%= icon("school", css: "text-xl text-cert-#{cert.slug}") %>
              <span class="text-sm font-medium text-on-surface font-body"><%= cert.name %></span>
            </div>
            <%# ラジオ実体は sr-only で保持。カスタム丸で視覚表現。 %>
            <span class="relative flex h-5 w-5 shrink-0 items-center justify-center">
              <%= f.radio_button :preferred_certification, cert.slug,
                    class: "peer sr-only" %>
              <span class="block h-5 w-5 rounded-full border-2 border-outline-variant bg-transparent transition-colors
                           peer-checked:border-primary peer-checked:bg-primary
                           peer-focus-visible:outline peer-focus-visible:outline-2 peer-focus-visible:outline-offset-2 peer-focus-visible:outline-[color:var(--color-focus)]"></span>
              <span class="pointer-events-none absolute h-2 w-2 rounded-full bg-on-primary opacity-0 transition-opacity peer-checked:opacity-100"></span>
            </span>
          </label>
        <% end %>
      </div>
    </section>

    <%# 3. 通知 %>
    <section>
      <h2 class="mb-2 text-label-caps font-label font-semibold uppercase tracking-widest text-on-surface-variant">通知</h2>
      <div class="card divide-y divide-outline-variant overflow-hidden">
        <%= render "settings/toggle_row",
              f: f,
              field: :morning_notification_enabled,
              label: "朝の通知",
              description: "今日のキューが届いたことをお知らせします" %>

        <%= render "settings/toggle_row",
              f: f,
              field: :evening_notification_enabled,
              label: "夜の通知",
              description: "一日の振り返りをお届けします" %>
      </div>
    </section>

    <%# 4. Calm Mode %>
    <section>
      <h2 class="mb-2 text-label-caps font-label font-semibold uppercase tracking-widest text-on-surface-variant">Calm Mode</h2>
      <div class="card divide-y divide-outline-variant overflow-hidden">
        <%= render "settings/toggle_row",
              f: f,
              field: :calm_mode,
              label: "Calm Mode",
              description: "試験前など、リングや通知を控えめにします" %>
      </div>
    </section>

    <%# 保存ボタン %>
    <div>
      <%= f.submit "保存",
            class: "btn btn-primary w-full" %>
    </div>

  <% end %>

  <%# 5. 二要素認証（フォーム外） %>
  <section>
    <h2 class="mb-2 text-label-caps font-label font-semibold uppercase tracking-widest text-on-surface-variant">二要素認証</h2>
    <div class="card divide-y divide-outline-variant overflow-hidden">
      <% if Current.user.otp_enabled? %>
        <div class="px-5 py-4 space-y-3">
          <div class="flex items-center gap-3">
            <%= icon("verified_user", css: "text-xl text-correct") %>
            <div>
              <p class="text-sm font-medium text-on-surface font-body">有効</p>
              <p class="text-xs text-on-surface-variant font-body">認証アプリによる二段階認証が設定されています</p>
            </div>
          </div>
          <%= form_with url: otp_path, method: :delete, class: "space-y-3" do |form| %>
            <div class="space-y-1">
              <%= form.label :code, "現在の認証コードを入力して無効化",
                    class: "block font-label text-xs font-semibold text-on-surface-variant" %>
              <%= form.text_field :code,
                    required: true,
                    autocomplete: "one-time-code",
                    inputmode: "numeric",
                    maxlength: 8,
                    placeholder: "000000",
                    class: "block w-full px-3 py-2 bg-surface-container-lowest border border-outline-variant rounded text-on-surface font-mono text-sm tracking-widest placeholder:text-outline focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary transition-shadow duration-200" %>
            </div>
            <%= form.submit "二要素認証を無効化する",
                  class: "btn btn-outline text-error border-error hover:bg-error-container w-full" %>
          <% end %>
        </div>
      <% else %>
        <%= link_to new_otp_path,
              class: "flex items-center justify-between gap-4 px-5 py-4 transition-colors hover:bg-surface-container" do %>
          <div class="flex items-center gap-3">
            <%= icon("security", css: "text-xl text-on-surface-variant") %>
            <div>
              <p class="text-sm font-medium text-on-surface font-body">未設定</p>
              <p class="text-xs text-on-surface-variant font-body">設定するとアカウントの安全性が高まります</p>
            </div>
          </div>
          <%= icon("chevron_right", css: "text-xl text-outline") %>
        <% end %>
      <% end %>
    </div>
  </section>

  <%# 6. アカウント（フォーム外） %>
  <section>
    <h2 class="mb-2 text-label-caps font-label font-semibold uppercase tracking-widest text-on-surface-variant">アカウント</h2>
    <div class="card divide-y divide-outline-variant overflow-hidden">

      <%# メールアドレス（表示のみ）%>
      <div class="flex items-center justify-between gap-4 px-5 py-4">
        <div class="flex items-center gap-3">
          <%= icon("mail", css: "text-xl text-on-surface-variant") %>
          <span class="text-sm font-medium text-on-surface font-body">メールアドレス</span>
        </div>
        <span class="text-sm text-on-surface-variant font-body truncate max-w-[200px]"><%= Current.user.email_address %></span>
      </div>

      <%# 自己ベスト（静かに表示。継続への煽りにならないよう終了後の記録として扱う）%>
      <div class="flex items-center justify-between gap-4 px-5 py-4">
        <div class="flex items-center gap-3">
          <%= icon("workspace_premium", css: "text-xl text-on-surface-variant") %>
          <span class="text-sm font-medium text-on-surface font-body">これまでの継続記録</span>
        </div>
        <span class="text-sm text-on-surface-variant font-body">自己ベスト <%= @user.longest_streak %> 日</span>
      </div>

      <%# パスワード変更 %>
      <%= link_to new_password_path,
            class: "flex items-center justify-between gap-4 px-5 py-4 transition-colors hover:bg-surface-container" do %>
        <div class="flex items-center gap-3">
          <%= icon("lock", css: "text-xl text-on-surface-variant") %>
          <span class="text-sm font-medium text-on-surface font-body">パスワードの変更</span>
        </div>
        <%= icon("chevron_right", css: "text-xl text-outline") %>
      <% end %>

      <%# ログアウト %>
      <div class="px-5 py-4">
        <%= button_to session_path, method: :delete,
              class: "flex w-full items-center gap-3 text-left text-sm text-error transition-opacity hover:opacity-70 font-body" do %>
          <%= icon("logout", css: "text-xl") %>
          ログアウト
        <% end %>
      </div>

    </div>
  </section>

</div>
