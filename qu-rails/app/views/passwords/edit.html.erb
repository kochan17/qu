<% content_for :title, "新しいパスワード" %>

<div class="min-h-screen flex items-center justify-center px-4 py-12 bg-gradient-to-br from-[color:var(--color-primary-fixed)] via-[color:var(--color-surface)] to-[color:var(--color-secondary-fixed)]">
  <div class="w-full max-w-md space-y-6">
    <div class="text-center">
      <span class="font-headline font-bold text-2xl text-on-surface tracking-tight">Qu</span>
      <h1 class="font-headline text-3xl font-bold text-on-surface mt-1">新しいパスワードを設定</h1>
      <p class="font-body text-sm text-on-surface-variant mt-1">新しいパスワードを入力してください</p>
    </div>

    <div class="card px-8 py-8 space-y-5">
      <%= form_with url: password_path(params[:token]), method: :put, class: "space-y-5" do |form| %>
        <% if @user.errors.any? %>
          <div class="rounded bg-error-container px-4 py-3 text-sm text-on-error-container">
            <ul class="list-disc space-y-0.5 pl-4">
              <% @user.errors.full_messages.each do |msg| %>
                <li><%= msg %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="space-y-1.5">
          <%= form.label :password, "新しいパスワード",
                class: "block font-label text-sm font-semibold text-on-surface" %>
          <div class="relative" data-controller="password-toggle">
            <%= form.password_field :password, required: true, autofocus: true,
                  autocomplete: "new-password", maxlength: 72,
                  data: { password_toggle_target: "input" },
                  class: "block w-full pl-3 pr-11 py-2.5 bg-surface-container-lowest border border-outline-variant rounded text-on-surface font-body text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary transition-shadow duration-200" %>
            <button type="button"
                    data-action="password-toggle#toggle"
                    class="absolute inset-y-0 right-0 flex items-center px-3 text-on-surface-variant transition-colors hover:text-on-surface"
                    aria-label="パスワードの表示を切り替える">
              <%= icon("visibility_off", css: "text-xl", data: { password_toggle_target: "icon" }) %>
            </button>
          </div>
        </div>

        <div class="space-y-1.5">
          <%= form.label :password_confirmation, "パスワード（確認）",
                class: "block font-label text-sm font-semibold text-on-surface" %>
          <div class="relative" data-controller="password-toggle">
            <%= form.password_field :password_confirmation, required: true,
                  autocomplete: "new-password", maxlength: 72,
                  data: { password_toggle_target: "input" },
                  class: "block w-full pl-3 pr-11 py-2.5 bg-surface-container-lowest border border-outline-variant rounded text-on-surface font-body text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary transition-shadow duration-200" %>
            <button type="button"
                    data-action="password-toggle#toggle"
                    class="absolute inset-y-0 right-0 flex items-center px-3 text-on-surface-variant transition-colors hover:text-on-surface"
                    aria-label="パスワードの表示を切り替える">
              <%= icon("visibility_off", css: "text-xl", data: { password_toggle_target: "icon" }) %>
            </button>
          </div>
        </div>

        <%= form.submit "パスワードを保存", class: "btn btn-primary btn-block btn-lg mt-2" %>
      <% end %>
    </div>
  </div>
</div>
