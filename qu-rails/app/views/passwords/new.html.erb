<% content_for :title, "パスワード再設定" %>

<div class="min-h-screen flex items-center justify-center px-4 py-12 bg-gradient-to-br from-[color:var(--color-primary-fixed)] via-[color:var(--color-surface)] to-[color:var(--color-secondary-fixed)]">
  <div class="w-full max-w-md space-y-6">
    <%# ワードマーク %>
    <div class="text-center">
      <span class="font-headline font-bold text-2xl text-on-surface tracking-tight">Qu</span>
      <h1 class="font-headline text-3xl font-bold text-on-surface mt-1">パスワードの再設定</h1>
      <p class="font-body text-sm text-on-surface-variant mt-1">登録済みのメールアドレスに再設定の手順をお送りします</p>
    </div>

    <%# カード %>
    <div class="card px-8 py-8 space-y-5">
      <%= form_with url: passwords_path, class: "space-y-5" do |form| %>
        <div class="space-y-1.5">
          <%= form.label :email_address, class: "block font-label text-sm font-semibold text-on-surface" do %>
            メールアドレス
          <% end %>
          <%= form.email_field :email_address, required: true, autofocus: true,
                autocomplete: "username", value: params[:email_address],
                placeholder: "name@example.com",
                class: "block w-full px-3 py-2.5 bg-surface-container-lowest border border-outline-variant rounded text-on-surface placeholder:text-outline font-body text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary transition-shadow duration-200" %>
        </div>

        <%= form.submit "再設定の手順を送る", class: "btn btn-primary btn-block btn-lg mt-2" %>
      <% end %>
    </div>

    <%# フッターリンク %>
    <p class="text-center font-body text-sm text-on-surface-variant">
      <%= link_to "ログインに戻る", new_session_path,
            class: "font-semibold text-brand-blue hover:underline" %>
    </p>
  </div>
</div>
