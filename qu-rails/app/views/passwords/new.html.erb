<% content_for :title, "パスワード再設定" %>

<div class="mx-auto max-w-sm py-6">
  <div class="text-center">
    <h1 class="text-xl font-semibold tracking-tight text-content">パスワードの再設定</h1>
    <p class="mt-2 text-sm text-content-faint">登録済みのメールアドレスに再設定の手順を送ります。</p>
  </div>

  <%= form_with url: passwords_path, class: "mt-8 space-y-5" do |form| %>
    <div class="space-y-1.5">
      <%= form.label :email_address, "メールアドレス", class: "text-sm font-medium text-content" %>
      <%= form.email_field :email_address, required: true, autofocus: true,
            autocomplete: "username", value: params[:email_address],
            class: "block w-full rounded-xl border border-border-subtle bg-surface-elevated px-3.5 py-2.5 text-sm text-content focus:border-tint focus:outline-none" %>
    </div>
    <%= form.submit "再設定の手順を送る",
          class: "w-full cursor-pointer rounded-xl bg-tint px-4 py-2.5 text-sm font-medium text-on-tint transition-opacity hover:opacity-90" %>
  <% end %>

  <p class="mt-6 text-center text-sm">
    <%= link_to "ログインに戻る", new_session_path, class: "text-content-faint hover:text-content" %>
  </p>
</div>
