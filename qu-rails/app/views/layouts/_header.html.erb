<%# 全ページ共通のトップナビ。プレーヤー・認証画面では描画しない（app_chrome? 参照）。 %>
<header class="sticky top-0 z-50 border-b border-outline-variant bg-surface">
  <div class="mx-auto flex max-w-7xl items-center gap-4 px-4 py-2.5 md:gap-6 md:px-6">
    <%= link_to "Qu", root_path, class: "shrink-0 text-2xl font-black text-on-surface" %>

    <%# courses#index は q を未使用。ナビの検索体験を保つための導線。 %>
    <%= form_with url: courses_path, method: :get, class: "hidden flex-1 md:block" do %>
      <div class="relative">
        <%= icon("search", css: "pointer-events-none absolute left-3 top-1/2 -translate-y-1/2 text-xl text-outline") %>
        <input type="search" name="q" placeholder="何を学びますか？"
               class="w-full rounded-full border border-on-surface bg-surface-container py-2 pl-10 pr-4 text-sm outline-none focus:ring-2 focus:ring-primary">
      </div>
    <% end %>

    <nav class="ml-auto flex items-center gap-5">
      <div class="hidden items-center gap-5 text-sm font-semibold lg:flex">
        <% nav_items.first(3).each do |key, label, path, _icon| %>
          <%= link_to label, path,
                class: (current_nav == key ? "text-primary" : "text-on-surface transition-colors hover:text-primary"),
                "aria-current": (current_nav == key ? "page" : nil) %>
        <% end %>
        <% if Current.user&.admin? %>
          <%= link_to "管理", admin_root_path, class: "text-on-surface transition-colors hover:text-primary" %>
        <% end %>
      </div>

      <%= link_to settings_path,
            class: "flex h-9 w-9 items-center justify-center rounded-full bg-primary-fixed text-primary",
            "aria-label": "設定" do %>
        <%= icon("person", filled: true, css: "text-xl") %>
      <% end %>

      <%= button_to session_path, method: :delete,
            class: "hidden text-on-surface-variant transition-colors hover:text-primary md:block",
            "aria-label": "ログアウト" do %>
        <%= icon("logout", css: "text-xl") %>
      <% end %>
    </nav>
  </div>
</header>
