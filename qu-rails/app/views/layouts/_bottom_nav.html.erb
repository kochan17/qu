<%# モバイル専用のボトムタブ。デスクトップではトップナビに集約する。 %>
<nav class="fixed inset-x-0 bottom-0 z-40 border-t border-outline-variant bg-surface md:hidden"
     style="padding-bottom: env(safe-area-inset-bottom)"
     aria-label="メインナビゲーション">
  <div class="flex items-stretch justify-around">
    <% nav_items.each do |key, label, path, icon_name| %>
      <% active = current_nav == key %>
      <%= link_to path,
            class: "flex flex-1 flex-col items-center gap-0.5 py-2 text-[0.7rem] font-medium transition-colors #{active ? "text-primary" : "text-on-surface-variant"}",
            "aria-current": (active ? "page" : nil) do %>
        <%= icon(icon_name, filled: active, css: "text-2xl") %>
        <span><%= label %></span>
      <% end %>
    <% end %>
  </div>
</nav>
