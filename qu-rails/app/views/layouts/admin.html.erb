<!DOCTYPE html>
<html lang="ja" class="scroll-smooth">
  <head>
    <title><%= content_for(:title).present? ? "#{content_for(:title)} — Qu Admin" : "Qu Admin" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta charset="utf-8">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <meta name="robots" content="noindex, nofollow, noai, noimageai">

    <link rel="icon" href="/icon.png" type="image/png">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700&family=Inter:wght@400;500;600;700&family=Public+Sans:wght@400;500;600;700;800;900&display=swap">
    <link rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body class="min-h-screen bg-surface-container-low font-body text-on-surface antialiased">
    <header class="sticky top-0 z-50 bg-on-surface text-white">
      <div class="mx-auto flex max-w-7xl items-center gap-6 px-4 py-3 md:px-6">
        <%= link_to "Qu Admin", admin_root_path, class: "shrink-0 text-lg font-black" %>

        <nav class="flex items-center gap-4 text-sm font-semibold">
          <%= link_to "ダッシュボード", admin_root_path,
                class: "text-white/80 transition-colors hover:text-white" %>
        </nav>

        <div class="ml-auto flex items-center gap-4 text-sm">
          <%= link_to root_path, class: "flex items-center gap-1 text-white/80 transition-colors hover:text-white" do %>
            <%= icon("arrow_back", css: "text-base") %>
            アプリに戻る
          <% end %>
          <%= button_to session_path, method: :delete,
                class: "text-white/80 transition-colors hover:text-white", "aria-label": "ログアウト" do %>
            <%= icon("logout", css: "text-lg") %>
          <% end %>
        </div>
      </div>
    </header>

    <main class="mx-auto w-full max-w-7xl px-4 py-8 md:px-6 md:py-10">
      <%= render "layouts/flash" %>
      <%= yield %>
    </main>
  </body>
</html>
