<footer class="bg-primary text-white">
  <div class="mx-auto grid max-w-7xl grid-cols-2 gap-8 px-6 py-12 md:grid-cols-4 md:py-14">
    <div class="col-span-2 md:col-span-1">
      <span class="block text-2xl font-black">Qu</span>
      <p class="mt-3 text-sm leading-relaxed text-white/80">資格の学びを、続けられる形に。</p>
    </div>

    <nav class="space-y-2.5 text-sm">
      <h4 class="font-label text-label-caps text-white">学ぶ</h4>
      <% nav_items.first(3).each do |_key, label, path, _icon| %>
        <%= link_to label, path, class: "block text-white/80 transition-colors hover:text-white" %>
      <% end %>
    </nav>

    <nav class="space-y-2.5 text-sm">
      <h4 class="font-label text-label-caps text-white">アカウント</h4>
      <%= link_to "設定", settings_path, class: "block text-white/80 transition-colors hover:text-white" %>
      <%= button_to "ログアウト", session_path, method: :delete,
            class: "block text-white/80 transition-colors hover:text-white" %>
    </nav>

    <div class="space-y-2.5 text-sm">
      <h4 class="font-label text-label-caps text-white">プラン</h4>
      <p class="text-white/80">月額 ¥980 で受け放題</p>
    </div>
  </div>

  <div class="border-t border-white/20">
    <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-5">
      <p class="text-xs text-white/70">© <%= Date.current.year %> Qu</p>
      <span class="flex items-center gap-1.5 text-xs text-white/70">
        <%= icon("language", css: "text-base") %> 日本語
      </span>
    </div>
  </div>
</footer>
