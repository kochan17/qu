<!DOCTYPE html>
<html lang="ja" class="scroll-smooth">
  <head>
    <title><%= content_for(:title).presence || "Qu" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="default">
    <meta name="theme-color" content="#faf8ff">
    <meta charset="utf-8">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%# AI クローラ向け不学習意思表示。 %>
    <meta name="robots" content="noai, noimageai">

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Web フォント — Public Sans / Inter / Geist + Material Symbols Outlined %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700&family=Inter:wght@400;500;600;700&family=Public+Sans:wght@400;500;600;700;800;900&display=swap">
    <link rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body class="min-h-screen antialiased font-body text-on-surface">
    <% if app_chrome? %>
      <div class="flex min-h-screen flex-col">
        <%= render "layouts/header" %>
        <main class="flex-1 pb-24 md:pb-12">
          <%= render "layouts/flash" %>
          <%= yield %>
        </main>
        <%= render "layouts/footer" %>
      </div>
      <%= render "layouts/bottom_nav" %>
    <% else %>
      <%= render "layouts/flash", chromeless: true %>
      <%= yield %>
    <% end %>
  </body>
</html>
