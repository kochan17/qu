<!DOCTYPE html>
<html lang="ja">
  <head>
    <title>Que</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta charset="utf-8">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body class="min-h-screen bg-neutral-50 text-neutral-900 antialiased">
    <%# chrome: backdrop-filter で Liquid Glass 風に。問題文の背後には使わない %>
    <header class="sticky top-0 z-50 border-b border-neutral-200/60 bg-white/80 backdrop-blur-md">
      <div class="mx-auto flex max-w-4xl items-center justify-between px-6 py-3">
        <a href="<%= root_path %>" class="text-lg font-semibold tracking-tight text-neutral-900">Que</a>

        <nav class="hidden items-center gap-6 text-sm text-neutral-500 sm:flex">
          <a href="<%= root_path %>" class="hover:text-neutral-900 transition-colors">Today</a>
          <span class="cursor-default text-neutral-300">Courses</span>
          <span class="cursor-default text-neutral-300">Settings</span>
        </nav>

        <div class="flex items-center gap-4 text-sm">
          <% if authenticated? %>
            <span class="text-neutral-500"><%= Current.user.display_name.presence || Current.user.email_address %></span>
            <%= button_to "ログアウト", session_path, method: :delete,
                class: "text-neutral-400 hover:text-neutral-700 transition-colors" %>
          <% else %>
            <%= link_to "ログイン", new_session_path, class: "text-neutral-500 hover:text-neutral-900 transition-colors" %>
          <% end %>
        </div>
      </div>
    </header>

    <% if notice.present? %>
      <div class="mx-auto max-w-4xl px-6 pt-4">
        <p class="rounded-xl bg-green-50 px-4 py-3 text-sm text-green-700"><%= notice %></p>
      </div>
    <% end %>
    <% if alert.present? %>
      <div class="mx-auto max-w-4xl px-6 pt-4">
        <p class="rounded-xl bg-red-50 px-4 py-3 text-sm text-red-600"><%= alert %></p>
      </div>
    <% end %>

    <main class="mx-auto max-w-4xl px-6 py-10">
      <%= yield %>
    </main>
  </body>
</html>
