<%# フラッシュメッセージ。chromeless: true で認証画面向けに画面上部へ固定する。 %>
<% chromeless = local_assigns.fetch(:chromeless, false) %>
<% if flash[:notice].present? || flash[:alert].present? %>
  <div class="<%= chromeless ? "fixed inset-x-0 top-4 z-50 mx-auto w-full max-w-md px-4" : "mx-auto max-w-7xl px-4 pt-4 md:px-6" %>"
       data-controller="flash" data-flash-dismiss-after-value="5000">
    <% if flash[:notice].present? %>
      <p class="rounded-lg border border-secondary-fixed-dim bg-secondary-container px-4 py-3 text-sm font-medium text-on-secondary-container">
        <%= flash[:notice] %>
      </p>
    <% end %>
    <% if flash[:alert].present? %>
      <p class="rounded-lg border border-error-container bg-error-container px-4 py-3 text-sm font-medium text-on-error-container">
        <%= flash[:alert] %>
      </p>
    <% end %>
  </div>
<% end %>
