<%# オンボーディング — 資格選択 + 1問プレビュー。
    chromeless レイアウト（グローバルナビなし）。フォーカスした全画面フロー。 %>
<% content_for :title, "ようこそ" %>

<div class="mx-auto max-w-xl py-4 sm:py-8">

  <%# ── ロゴ ──────────────────────────────────────────────── %>
  <div class="mb-8 text-center sm:mb-10">
    <p class="text-xl font-semibold tracking-tight text-content">Que</p>
  </div>

  <% if @selected.nil? %>
    <%# ── ステップ 1: 資格を選ぶ ──────────────────────────── %>

    <div class="mb-8 text-center">
      <h1 class="text-2xl font-semibold tracking-tight text-content">学びたい資格を選びましょう</h1>
      <p class="mt-2 text-sm text-content-muted">あとからでも変更できます。</p>
    </div>

    <div class="space-y-3">
      <% @certifications.each do |cert| %>
        <%= link_to onboarding_path(certification: cert.slug),
              class: "group flex items-center justify-between rounded-2xl border border-border-subtle bg-surface-elevated px-5 py-4 transition-colors hover:bg-surface-sunken" do %>
          <div class="flex items-center gap-4">
            <div class="h-10 w-1 flex-none rounded-full bg-cert-<%= cert.slug %>"></div>
            <div>
              <p class="text-sm font-medium text-content"><%= cert.name %></p>
              <% if cert.description.present? %>
                <p class="mt-0.5 text-xs text-content-muted line-clamp-1"><%= cert.description %></p>
              <% end %>
            </div>
          </div>
          <%= icon("chevron_right", css: "text-xl text-content-faint flex-none transition-transform group-hover:translate-x-0.5") %>
        <% end %>
      <% end %>
    </div>

  <% else %>
    <%# ── ステップ 2: 選択確認 + 1問プレビュー ────────────── %>

    <div class="mb-6">
      <%= link_to onboarding_path,
            class: "inline-flex items-center gap-1 text-sm text-content-muted transition-colors hover:text-content" do %>
        <%= icon("arrow_back", css: "text-[1.1rem]") %>
        <span>資格を選び直す</span>
      <% end %>
    </div>

    <div class="flex items-center gap-3 mb-6">
      <div class="h-8 w-1.5 flex-none rounded-full bg-cert-<%= @selected.slug %>"></div>
      <div>
        <h1 class="text-xl font-semibold tracking-tight text-content"><%= @selected.name %></h1>
        <% if @selected.description.present? %>
          <p class="mt-0.5 text-sm text-content-muted"><%= @selected.description %></p>
        <% end %>
      </div>
    </div>

    <% if @preview_question %>
      <%# ── 1問プレビュー ──────────────────────────────────── %>
      <div class="mb-6 rounded-2xl border border-border-subtle bg-surface-elevated p-5 sm:p-6"
           data-controller="onboarding"
           data-onboarding-correct-id-value="<%= @preview_question.correct_choice_id %>">

        <p class="mb-1 text-xs font-medium text-content-faint uppercase tracking-wider">
          まず1問、体験してみましょう
        </p>

        <p class="mt-3 text-base leading-relaxed text-content">
          <%= @preview_question.question_text %>
        </p>

        <div class="mt-5 space-y-2.5">
          <% Array(@preview_question.choices).each_with_index do |choice, i| %>
            <button type="button"
                    class="choice-btn w-full rounded-xl border border-border-subtle bg-surface px-4 py-3 text-left text-sm text-content transition-colors hover:bg-surface-sunken focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-tint"
                    data-onboarding-target="choice"
                    data-choice-id="<%= choice["id"] %>"
                    data-action="click->onboarding#selectChoice">
              <span class="mr-2 font-medium text-content-muted"><%= (i + 1) %>.</span>
              <%= choice["text"] %>
            </button>
          <% end %>
        </div>

        <%# 解説エリア（選択後に表示） %>
        <div class="mt-4 hidden" data-onboarding-target="feedback">
          <div class="rounded-xl px-4 py-3 text-sm" data-onboarding-target="feedbackBadge">
          </div>
          <% if @preview_question.explanation.present? %>
            <div class="mt-3 rounded-xl bg-surface-sunken px-4 py-3 text-sm text-content-muted" data-onboarding-target="explanation">
              <%= @preview_question.explanation %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <%# ── 「この資格ではじめる」ボタン ──────────────────────── %>
    <%= form_with url: onboarding_path, method: :patch do |f| %>
      <%= f.hidden_field :certification, value: @selected.slug %>
      <%= f.submit "この資格ではじめる",
            class: "w-full cursor-pointer rounded-2xl bg-tint px-5 py-3.5 text-sm font-semibold text-on-tint transition-opacity hover:opacity-90" %>
    <% end %>
  <% end %>

</div>
