<% content_for :title, "アカウント作成" %>

<div class="mx-auto max-w-sm py-6">
  <div class="text-center">
    <p class="text-2xl font-semibold tracking-tight text-content">Que</p>
    <p class="mt-2 text-sm text-content-faint">資格学習を始めましょう。</p>
  </div>

  <%= form_with model: @user, url: registration_path, class: "mt-10 space-y-5" do |f| %>
    <% if @user.errors.any? %>
      <div class="rounded-xl bg-incorrect-soft px-4 py-3 text-sm text-incorrect">
        <ul class="list-disc space-y-0.5 pl-4">
          <% @user.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="space-y-1.5">
      <%= f.label :display_name, "表示名", class: "text-sm font-medium text-content" %>
      <%= f.text_field :display_name, autocomplete: "name",
            class: "block w-full rounded-xl border border-border-subtle bg-surface-elevated px-3.5 py-2.5 text-sm text-content focus:border-tint focus:outline-none" %>
    </div>

    <div class="space-y-1.5">
      <%= f.label :email_address, "メールアドレス", class: "text-sm font-medium text-content" %>
      <%= f.email_field :email_address, required: true, autocomplete: "email",
            class: "block w-full rounded-xl border border-border-subtle bg-surface-elevated px-3.5 py-2.5 text-sm text-content focus:border-tint focus:outline-none" %>
    </div>

    <div class="space-y-1.5">
      <%= f.label :password, "パスワード", class: "text-sm font-medium text-content" %>
      <%= f.password_field :password, required: true, autocomplete: "new-password",
            class: "block w-full rounded-xl border border-border-subtle bg-surface-elevated px-3.5 py-2.5 text-sm text-content focus:border-tint focus:outline-none" %>
    </div>

    <div class="space-y-1.5">
      <%= f.label :password_confirmation, "パスワード（確認）", class: "text-sm font-medium text-content" %>
      <%= f.password_field :password_confirmation, required: true, autocomplete: "new-password",
            class: "block w-full rounded-xl border border-border-subtle bg-surface-elevated px-3.5 py-2.5 text-sm text-content focus:border-tint focus:outline-none" %>
    </div>

    <%= f.submit "アカウントを作成",
          class: "w-full cursor-pointer rounded-xl bg-tint px-4 py-2.5 text-sm font-medium text-on-tint transition-opacity hover:opacity-90" %>
  <% end %>

  <p class="mt-6 text-center text-sm text-content-faint">
    すでにアカウントをお持ちの方は
    <%= link_to "ログイン", new_session_path, class: "font-medium text-tint hover:opacity-80" %>
  </p>
</div>
