<% content_for :title, "アカウント作成" %>
<div class="mx-auto max-w-sm">
  <h1 class="text-2xl font-semibold tracking-tight">アカウント作成</h1>
  <p class="mt-1 text-sm text-neutral-400">Que で資格学習を始めましょう。</p>

  <%= form_with model: @user, url: registration_path, class: "mt-8 space-y-5" do |f| %>
    <% if @user.errors.any? %>
      <div class="rounded-xl bg-red-50 px-4 py-3 text-sm text-red-600">
        <ul class="list-disc space-y-0.5 pl-4">
          <% @user.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="space-y-1.5">
      <%= f.label :display_name, "表示名", class: "text-sm font-medium text-neutral-700" %>
      <%= f.text_field :display_name, autocomplete: "name",
            class: "block w-full rounded-xl border border-neutral-200 px-3.5 py-2.5 text-sm focus:border-indigo-400 focus:outline-none focus:ring-2 focus:ring-indigo-100" %>
    </div>

    <div class="space-y-1.5">
      <%= f.label :email_address, "メールアドレス", class: "text-sm font-medium text-neutral-700" %>
      <%= f.email_field :email_address, required: true, autocomplete: "email",
            class: "block w-full rounded-xl border border-neutral-200 px-3.5 py-2.5 text-sm focus:border-indigo-400 focus:outline-none focus:ring-2 focus:ring-indigo-100" %>
    </div>

    <div class="space-y-1.5">
      <%= f.label :password, "パスワード", class: "text-sm font-medium text-neutral-700" %>
      <%= f.password_field :password, required: true, autocomplete: "new-password",
            class: "block w-full rounded-xl border border-neutral-200 px-3.5 py-2.5 text-sm focus:border-indigo-400 focus:outline-none focus:ring-2 focus:ring-indigo-100" %>
    </div>

    <div class="space-y-1.5">
      <%= f.label :password_confirmation, "パスワード（確認）", class: "text-sm font-medium text-neutral-700" %>
      <%= f.password_field :password_confirmation, required: true, autocomplete: "new-password",
            class: "block w-full rounded-xl border border-neutral-200 px-3.5 py-2.5 text-sm focus:border-indigo-400 focus:outline-none focus:ring-2 focus:ring-indigo-100" %>
    </div>

    <%= f.submit "アカウントを作成",
          class: "w-full cursor-pointer rounded-xl bg-indigo-600 px-4 py-2.5 text-sm font-medium text-white transition-colors hover:bg-indigo-700" %>
  <% end %>

  <p class="mt-6 text-center text-sm text-neutral-400">
    すでにアカウントをお持ちの方は
    <%= link_to "ログイン", new_session_path, class: "text-indigo-600 hover:text-indigo-700" %>
  </p>
</div>
