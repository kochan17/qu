<%# 演習キューが空のときの状態。引数: lesson（任意）/ daily_completed %>
<div class="rounded-2xl border border-border-subtle bg-surface-elevated px-6 py-12 text-center">
  <% if lesson %>
    <%= icon("task_alt", filled: true, css: "text-4xl text-tint") %>
    <p class="mt-3 text-base font-medium text-content">このレッスンの演習を終えました</p>
    <p class="mt-1 text-sm text-content-faint">ここまでよく取り組めています。</p>
    <div class="mt-6 flex flex-col gap-2 sm:flex-row sm:justify-center">
      <%= link_to "レッスンに戻る", lesson_path(lesson),
            class: "rounded-xl bg-tint px-5 py-2.5 text-sm font-medium text-on-tint" %>
      <%= link_to "Today へ", root_path,
            class: "rounded-xl border border-border-subtle px-5 py-2.5 text-sm font-medium text-content transition-colors hover:bg-surface-sunken" %>
    </div>

  <% elsif daily_completed %>
    <%= icon("check_circle", filled: true, css: "text-4xl text-tint") %>
    <p class="mt-3 text-base font-medium text-content">今日の目標を達成しました</p>
    <p class="mt-1 text-sm text-content-faint">ここまでよく続けています。</p>
    <div class="mt-6 flex flex-col gap-2 sm:flex-row sm:justify-center">
      <%= link_to "Today へ", root_path,
            class: "rounded-xl bg-tint px-5 py-2.5 text-sm font-medium text-on-tint" %>
      <%= link_to "新しい単元を学ぶ", courses_path,
            class: "rounded-xl border border-border-subtle px-5 py-2.5 text-sm font-medium text-content transition-colors hover:bg-surface-sunken" %>
    </div>

  <% else %>
    <%= icon("inbox", css: "text-4xl text-content-faint") %>
    <p class="mt-3 text-base font-medium text-content">今日のキューは空です</p>
    <p class="mt-1 text-sm text-content-faint">新しい単元を学ぶと、また演習が届きます。</p>
    <div class="mt-6 flex flex-col gap-2 sm:flex-row sm:justify-center">
      <%= link_to "新しい単元を学ぶ", courses_path,
            class: "rounded-xl bg-tint px-5 py-2.5 text-sm font-medium text-on-tint" %>
      <%= link_to "Today へ", root_path,
            class: "rounded-xl border border-border-subtle px-5 py-2.5 text-sm font-medium text-content transition-colors hover:bg-surface-sunken" %>
    </div>
  <% end %>
</div>
