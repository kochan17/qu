<%# 演習キューが空のときの完了画面。引数: lesson（任意）/ daily_completed %>
<div class="card px-6 py-10 text-center space-y-4">
  <% if lesson %>
    <%= icon("task_alt", filled: true, css: "text-5xl text-primary") %>
    <div>
      <p class="font-headline text-lg font-bold text-on-surface">
        このレッスンの演習を終えました
      </p>
      <p class="mt-1 font-body text-sm text-on-surface-variant">
        ここまでよく取り組めています。
      </p>
    </div>
    <div class="flex flex-col gap-2 sm:flex-row sm:justify-center pt-2">
      <%= link_to "レッスンに戻る", lesson_path(lesson), class: "btn btn-primary btn-sm" %>
      <%= link_to "ダッシュボードへ", root_path, class: "btn btn-outline btn-sm" %>
    </div>

  <% elsif daily_completed %>
    <%= icon("check_circle", filled: true, css: "text-5xl text-primary") %>
    <div>
      <p class="font-headline text-lg font-bold text-on-surface">
        今日の目標を達成しました
      </p>
      <p class="mt-1 font-body text-sm text-on-surface-variant">
        ここまでよく続けています。
      </p>
    </div>
    <div class="flex flex-col gap-2 sm:flex-row sm:justify-center pt-2">
      <%= link_to "ダッシュボードへ", root_path, class: "btn btn-primary btn-sm" %>
      <%= link_to "新しい単元を学ぶ", courses_path, class: "btn btn-outline btn-sm" %>
    </div>

  <% else %>
    <%= icon("inbox", css: "text-5xl text-on-surface-variant") %>
    <div>
      <p class="font-headline text-lg font-bold text-on-surface">
        今日のキューは空です
      </p>
      <p class="mt-1 font-body text-sm text-on-surface-variant">
        新しい単元を学ぶと、また演習が届きます。
      </p>
    </div>
    <div class="flex flex-col gap-2 sm:flex-row sm:justify-center pt-2">
      <%= link_to "新しい単元を学ぶ", courses_path, class: "btn btn-primary btn-sm" %>
      <%= link_to "ダッシュボードへ", root_path, class: "btn btn-outline btn-sm" %>
    </div>
  <% end %>
</div>
