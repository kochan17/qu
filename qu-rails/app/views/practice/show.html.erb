<%# 演習画面 — Udemy 風。1 画面 1 問。 %>
<% content_for :title, "演習" %>

<div class="mx-auto max-w-3xl px-4 py-10 md:py-14 space-y-6 sm:px-0">

  <%# ヘッダ %>
  <header class="flex items-center justify-between gap-4">
    <%= link_to (practice_lesson ? lesson_path(practice_lesson) : root_path),
          class: "inline-flex items-center gap-1 text-sm text-on-surface-variant hover:text-on-surface transition-colors" do %>
      <%= icon("arrow_back", css: "text-base") %>
      <span><%= practice_lesson ? practice_lesson.title : "ダッシュボード" %></span>
    <% end %>
    <span class="text-sm font-medium text-on-surface-variant">
      <%= practice_lesson ? "レッスン演習" : "今日の演習" %>
    </span>
  </header>

  <%# 進捗バー %>
  <div id="practice_progress">
    <%= render "practice/progress", progress: @progress %>
  </div>

  <%# 問題カード（Turbo Frame — フィードバック差し替え対象） %>
  <turbo-frame id="practice_card">
    <% if @question %>
      <%= render "practice/question", question: @question, lesson_id: practice_lesson&.id %>
    <% else %>
      <%= render "practice/done", lesson: practice_lesson, daily_completed: @daily_completed %>
    <% end %>
  </turbo-frame>

</div>
