<%# 演習画面 — Apple Journal × CBT。余白を最大に、1 画面 1 問。 %>
<% content_for :title, "演習" %>

<div class="mx-auto max-w-2xl space-y-6">

  <%# ── 最小ツールバー ───────────────────────────────────────── %>
  <header class="flex items-center justify-between">
    <%= link_to (practice_lesson ? lesson_path(practice_lesson) : root_path),
          class: "flex items-center gap-1 text-sm text-content-faint transition-colors hover:text-content" do %>
      <%= icon("arrow_back", css: "text-lg") %>
      <span><%= practice_lesson ? "レッスン" : "Today" %></span>
    <% end %>
    <p class="text-sm font-medium text-content">
      <%= practice_lesson ? "レッスンの演習" : "今日の演習" %>
    </p>
    <span class="w-14"></span>
  </header>

  <%# ── 進捗（進捗バーは後退しない — Safe Failure Design）──────── %>
  <div id="practice_progress">
    <%= render "practice/progress", progress: @progress %>
  </div>

  <%# ── 問題カード ───────────────────────────────────────────── %>
  <turbo-frame id="practice_card">
    <% if @question %>
      <%= render "practice/question", question: @question, lesson_id: practice_lesson&.id %>
    <% else %>
      <%= render "practice/done", lesson: practice_lesson, daily_completed: @daily_completed %>
    <% end %>
  </turbo-frame>

</div>
