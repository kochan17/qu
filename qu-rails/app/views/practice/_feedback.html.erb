<%# 解答後フィードバック。引数: result（QuizResult）/ lesson_id
    正解=correct トークン / 不正解=incorrect トークン。揺れ/shake なし。
    answer_choice_tone ヘルパーで border/bg クラスを付与する。 %>
<% question = result.question %>

<div class="card px-5 py-6 md:px-8 space-y-5">

  <%# 問題文（再掲）%>
  <div class="flex items-start gap-3">
    <span class="flex h-7 w-7 flex-shrink-0 items-center justify-center rounded bg-surface-container-high font-label text-xs font-bold text-on-surface-variant">
      Q
    </span>
    <p class="font-body text-base leading-relaxed text-on-surface md:text-lg">
      <%= question.question_text %>
    </p>
  </div>

  <%# 選択肢（結果表示）%>
  <div class="space-y-2" role="list">
    <% letters = %w[A B C D E F] %>
    <% Array(question.choices).each_with_index do |choice, i| %>
      <% is_answer   = question.correct?(choice["id"]) %>
      <% is_selected = choice["id"].to_s == result.selected_choice_id.to_s %>
      <div class="flex items-center gap-3 rounded-md border px-4 py-3 <%= answer_choice_tone(question, choice, result) %>"
           role="listitem">
        <span class="flex h-6 w-6 flex-shrink-0 items-center justify-center rounded font-label text-xs font-semibold text-on-surface-variant bg-surface-container-high">
          <%= letters[i] %>
        </span>
        <span class="flex-1 font-body text-sm leading-relaxed text-on-surface">
          <%= choice["text"] %>
        </span>
        <% if is_answer %>
          <%= icon("check_circle", filled: true, css: "text-xl text-correct") %>
        <% elsif is_selected %>
          <%= icon("cancel", filled: true, css: "text-xl text-incorrect") %>
        <% end %>
      </div>
    <% end %>
  </div>

  <%# 結果バナー + 解説 %>
  <div class="rounded-md border px-5 py-4 space-y-2
              <%= result.is_correct? ? "border-correct bg-correct-soft" : "border-incorrect bg-incorrect-soft" %>">
    <p class="font-label text-sm font-semibold
              <%= result.is_correct? ? "text-correct" : "text-incorrect" %>">
      <%= result.is_correct? ? "正解です" : "あと一歩。解説で確認しておきましょう" %>
    </p>
    <% if question.explanation.present? %>
      <p class="font-body text-sm leading-relaxed text-on-surface">
        <%= question.explanation %>
      </p>
    <% end %>
  </div>

  <%# 次の問題へ %>
  <%= link_to practice_path(lesson_id: lesson_id),
        data: { turbo_frame: "practice_card" },
        class: "btn btn-primary btn-block" do %>
    次の問題へ
    <%= icon("arrow_forward", css: "text-base") %>
  <% end %>

</div>
