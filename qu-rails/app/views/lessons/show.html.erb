<%# レッスン詳細 — Apple Journal 風、余白最大で本文に集中できる構成。 %>
<% content_for :title, @lesson.title %>

<div class="mx-auto max-w-2xl space-y-8">

  <%# ── 戻るリンク ──────────────────────────────────────────── %>
  <%= link_to course_path(@course),
        class: "inline-flex items-center gap-1 text-sm text-tint transition-colors hover:text-tint-strong" do %>
    <%= icon("arrow_back_ios", css: "text-base") %>
    <span><%= @course.title %></span>
  <% end %>

  <%# ── ヘッダ ──────────────────────────────────────────────── %>
  <header class="space-y-3">
    <%# セクション名 %>
    <p class="text-xs font-medium uppercase tracking-wider text-content-faint"><%= @section.title %></p>

    <h1 class="text-2xl font-semibold leading-snug tracking-tight text-content"><%= @lesson.title %></h1>

    <% if @lesson.intro.present? %>
      <p class="text-base leading-relaxed text-content-muted"><%= @lesson.intro %></p>
    <% end %>

    <%# 所要時間 %>
    <% if @lesson.duration_seconds.present? && @lesson.duration_seconds > 0 %>
      <p class="flex items-center gap-1 text-xs text-content-faint">
        <%= icon("schedule", css: "text-base") %>
        約<%= (@lesson.duration_seconds / 60.0).ceil %>分
      </p>
    <% end %>
  </header>

  <%# ── なぜ大切か（why_matters コールアウト）─────────────────── %>
  <% if @lesson.why_matters.present? %>
    <aside class="rounded-2xl bg-tint-soft px-5 py-4 space-y-1.5">
      <p class="text-xs font-semibold text-tint">なぜ大切か</p>
      <p class="text-sm leading-relaxed text-content"><%= @lesson.why_matters %></p>
    </aside>
  <% end %>

  <%# ── レッスン本文 ────────────────────────────────────────── %>
  <% if @lesson.body.present? %>
    <div class="lesson-prose">
      <%= render_markdown(@lesson.body) %>
    </div>
  <% else %>
    <div class="rounded-2xl border border-border-subtle bg-surface-elevated px-6 py-10 text-center">
      <%= icon("auto_stories", css: "text-4xl text-content-faint") %>
      <p class="mt-3 text-sm text-content-muted">本文を準備中です。</p>
    </div>
  <% end %>

  <%# ── フッタアクション ───────────────────────────────────────── %>
  <footer class="space-y-3 border-t border-border-subtle pt-6">

    <%# 完了ボタン %>
    <% if @completed %>
      <div class="flex items-center gap-2 text-sm text-tint">
        <%= icon("check_circle", filled: true, css: "text-xl") %>
        <span>完了済み</span>
      </div>
    <% else %>
      <%= button_to lesson_completion_path(@lesson), method: :post,
            class: "w-full rounded-xl bg-tint px-5 py-3 text-sm font-medium text-on-tint transition-colors hover:bg-tint-strong" do %>
        このレッスンを完了にする
      <% end %>
    <% end %>

    <%# 演習ボタン — 公開問題がある時のみ表示 %>
    <% if @has_questions %>
      <%= link_to practice_path(lesson_id: @lesson.id),
            class: "flex w-full items-center justify-center gap-2 rounded-xl border border-border-subtle px-5 py-3 text-sm font-medium text-content transition-colors hover:bg-surface-sunken" do %>
        <%= icon("quiz", css: "text-xl text-content-muted") %>
        このレッスンを演習する
      <% end %>
    <% end %>

  </footer>

</div>
