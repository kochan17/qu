<%# コースカード — Udemy 風横長レイアウト（サムネ左・テキスト右・進捗バー）。
    locals: course, cert_slug, progress = { total:, completed: } %>

<%
  pct = progress[:total].positive? ?
    [ (progress[:completed].to_f / progress[:total] * 100).round, 100 ].min : 0
  completed_all = progress[:total].positive? && progress[:completed] >= progress[:total]
  cover_color_var = {
    "ip"    => "--color-cert-ip",
    "fe"    => "--color-cert-fe",
    "genai" => "--color-cert-genai",
    "gken"  => "--color-cert-gken"
  }[cert_slug] || "--color-brand-blue"
%>

<%= link_to course_path(course), class: "group course-card flex flex-col overflow-hidden rounded-lg" do %>
  <%# サムネイル %>
  <div class="relative aspect-video w-full overflow-hidden">
    <% if course.thumbnail_url.present? %>
      <img src="<%= course.thumbnail_url %>"
           alt="<%= course.title %>"
           class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105">
    <% else %>
      <div class="flex h-full w-full flex-col items-center justify-center gap-2 p-4"
           style="background-color: var(<%= cover_color_var %>);">
        <%= icon("menu_book", filled: true, css: "text-4xl text-white opacity-80") %>
      </div>
    <% end %>

    <% if completed_all %>
      <div class="absolute right-2 top-2">
        <%= icon("check_circle", filled: true, css: "text-2xl text-secondary") %>
      </div>
    <% end %>
  </div>

  <%# テキストエリア %>
  <div class="flex flex-1 flex-col gap-2 p-3">
    <p class="font-headline text-sm font-bold leading-snug text-on-surface line-clamp-2">
      <%= course.title %>
    </p>

    <% if progress[:total].positive? %>
      <div class="mt-auto space-y-1">
        <div class="h-1.5 overflow-hidden rounded-full bg-surface-container-high">
          <div class="h-full rounded-full bg-brand-blue transition-all duration-500"
               style="width: <%= pct %>%"></div>
        </div>
        <p class="font-label text-xs text-on-surface-variant tabular-nums">
          <% if completed_all %>
            <span class="text-secondary font-semibold">修了</span>
          <% else %>
            <%= pct %>% 完了
          <% end %>
        </p>
      </div>
    <% else %>
      <p class="font-label text-xs text-outline mt-auto">レッスン準備中</p>
    <% end %>
  </div>
<% end %>
