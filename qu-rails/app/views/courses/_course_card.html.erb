<%# コースカード — Apple Books 風カバー主体。
    locals: course, cert_slug, progress = { total:, completed: } %>

<%
  pct = progress[:total].positive? ?
    [ (progress[:completed].to_f / progress[:total] * 100).round, 100 ].min : 0
  cert_color_class = {
    "ip"    => "cert-ip",
    "fe"    => "cert-fe",
    "genai" => "cert-genai",
    "gken"  => "cert-gken"
  }[cert_slug] || "tint"
%>

<%= link_to course_path(course), class: "group flex flex-col gap-2" do %>
  <%# カバー %>
  <div class="relative aspect-[3/4] w-full overflow-hidden rounded-xl border border-border-subtle transition-transform duration-200 group-hover:scale-[1.02]">
    <% if course.thumbnail_url.present? %>
      <img src="<%= course.thumbnail_url %>"
           alt="<%= course.title %>"
           class="h-full w-full object-cover">
    <% else %>
      <%# サムネイルなし — 資格カラーの単色カバーにコース名を載せる %>
      <div class="flex h-full w-full flex-col items-center justify-center gap-3 p-4"
           style="background-color: var(--<%= cert_color_class %>);">
        <%= icon("menu_book", filled: true, css: "text-4xl text-on-tint opacity-80") %>
        <p class="text-center text-sm font-semibold leading-snug text-on-tint"><%= course.title %></p>
      </div>
    <% end %>

    <%# 完了バッジ %>
    <% if progress[:total].positive? && progress[:completed] >= progress[:total] %>
      <div class="absolute right-2 top-2">
        <%= icon("check_circle", filled: true, css: "text-xl text-on-tint") %>
      </div>
    <% end %>
  </div>

  <%# タイトル + 進捗 %>
  <div class="space-y-1.5 px-0.5">
    <p class="text-sm font-medium leading-snug text-content line-clamp-2"><%= course.title %></p>

    <% if progress[:total].positive? %>
      <div class="space-y-1">
        <p class="text-xs text-content-faint tabular-nums">
          <%= progress[:completed] %> / <%= progress[:total] %> レッスン
        </p>
        <div class="h-1 overflow-hidden rounded-full bg-surface-sunken">
          <div class="h-full rounded-full bg-tint transition-all duration-500"
               style="width: <%= pct %>%"></div>
        </div>
      </div>
    <% else %>
      <p class="text-xs text-content-faint">レッスンなし</p>
    <% end %>
  </div>
<% end %>
