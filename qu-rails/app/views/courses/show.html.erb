<%# コース詳細 — Udemy 風レイアウト（ヒーロー帯 + 2 カラム本体）。 %>
<% content_for :title, @course.title %>

<%
  cover_color_var = {
    "ip"    => "--color-cert-ip",
    "fe"    => "--color-cert-fe",
    "genai" => "--color-cert-genai",
    "gken"  => "--color-cert-gken"
  }[@course.certification.slug] || "--color-brand-blue"

  first_lesson = @sections.filter_map { |s| @lessons_by_section[s.id]&.first }.first
  pct = @total_lessons.positive? ?
    [ (@completed_lessons.to_f / @total_lessons * 100).round, 100 ].min : 0
%>

<%# フルブリードのヒーロー帯。通常コンテンツを -mx で外に出して全幅にする。
    右のサブスクカードがこの帯へ食い込むため下余白を広めに取る。 %>
<div class="-mx-4 bg-brand-blue py-8 text-white md:-mx-6 md:py-12 lg:pb-32">
  <div class="mx-auto grid max-w-7xl grid-cols-1 gap-8 px-4 md:px-6 lg:grid-cols-3 lg:gap-12">
    <div class="space-y-4 lg:col-span-2">
      <nav class="flex flex-wrap items-center gap-1.5 text-sm font-semibold text-primary-fixed-dim">
        <%= link_to @course.certification.name, courses_path, class: "transition-colors hover:text-white" %>
        <span class="text-white/40">/</span>
        <span class="truncate text-white/80"><%= @course.title %></span>
      </nav>

      <h1 class="font-headline text-2xl font-bold leading-tight md:text-3xl"><%= @course.title %></h1>

      <% if @course.description.present? %>
        <p class="max-w-2xl text-base leading-relaxed text-white/90"><%= @course.description %></p>
      <% end %>

      <div class="flex flex-wrap items-center gap-x-5 gap-y-2 text-sm text-white/80">
        <span class="flex items-center gap-1">
          <%= icon("layers", css: "text-base") %><%= @sections.size %>セクション
        </span>
        <span class="flex items-center gap-1">
          <%= icon("play_lesson", css: "text-base") %><%= @total_lessons %>レッスン
        </span>
        <% if @completed_lessons.positive? %>
          <span class="flex items-center gap-1 font-semibold text-secondary-fixed-dim">
            <%= icon("check_circle", filled: true, css: "text-base") %><%= @completed_lessons %>レッスン修了
          </span>
        <% end %>
      </div>
    </div>
  </div>
</div>

<div class="mx-auto grid max-w-7xl grid-cols-1 gap-8 px-4 pt-8 md:px-6 lg:grid-cols-3 lg:gap-12">
  <div class="space-y-10 lg:col-span-2">

    <%# 進捗と CTA のモバイル版。デスクトップは右のサブスクカードが担う。 %>
    <div class="card overflow-hidden lg:hidden">
      <% if @total_lessons.positive? %>
        <div class="space-y-1.5 px-5 pb-3 pt-5">
          <div class="flex items-center justify-between">
            <p class="font-label text-xs font-semibold text-on-surface-variant">学習の進捗</p>
            <p class="font-label text-xs tabular-nums text-on-surface-variant">
              <span class="font-semibold text-on-surface"><%= @completed_lessons %></span> / <%= @total_lessons %>
            </p>
          </div>
          <div class="h-2 overflow-hidden rounded-full bg-surface-container-high">
            <div class="h-full rounded-full bg-brand-blue transition-all duration-700" style="width: <%= pct %>%"></div>
          </div>
        </div>
      <% end %>
      <% if first_lesson %>
        <div class="px-5 pb-5 <%= "pt-5" unless @total_lessons.positive? %>">
          <%= link_to lesson_path(first_lesson), class: "btn btn-primary btn-block" do %>
            <%= icon("play_arrow", filled: true, css: "text-xl") %>
            <%= @completed_lessons.positive? ? "学習を続ける" : "学習を始める" %>
          <% end %>
        </div>
      <% end %>
    </div>

    <section>
      <div class="mb-4 flex items-baseline justify-between">
        <h2 class="font-headline text-xl font-bold text-on-surface">コースの内容</h2>
        <% if @total_lessons.positive? %>
          <p class="text-sm text-on-surface-variant">
            <%= @sections.size %>セクション・<%= @total_lessons %>レッスン
          </p>
        <% end %>
      </div>

      <% if @sections.empty? %>
        <div class="card space-y-3 px-6 py-12 text-center">
          <%= icon("auto_stories", css: "text-3xl text-on-surface-variant") %>
          <p class="text-sm text-on-surface-variant">セクションを準備中です。</p>
        </div>
      <% else %>
        <div class="divide-y divide-outline-variant overflow-hidden rounded-lg border border-outline-variant">
          <% @sections.each_with_index do |section, idx| %>
            <% published_lessons = @lessons_by_section[section.id] || [] %>
            <% section_done = published_lessons.count { |l| @completed_lesson_ids.include?(l.id) } %>

            <div data-controller="accordion" data-accordion-open-value="<%= idx.zero? %>">
              <button type="button" data-action="accordion#toggle"
                      class="flex w-full items-center justify-between bg-surface-container p-4 text-left transition-colors hover:bg-surface-container-high">
                <span class="flex min-w-0 items-center gap-3">
                  <%= icon("expand_more",
                        css: "shrink-0 text-xl text-on-surface-variant transition-transform duration-200",
                        data: { accordion_target: "icon" }) %>
                  <span class="truncate font-headline text-sm font-bold text-on-surface"><%= section.title %></span>
                </span>
                <span class="ml-4 shrink-0 font-label text-xs tabular-nums text-on-surface-variant">
                  <%= published_lessons.size %>レッスン<% if section_done.positive? %>・<span class="font-semibold text-secondary"><%= section_done %>修了</span><% end %>
                </span>
              </button>

              <div data-accordion-target="panel"
                   class="<%= "hidden" unless idx.zero? %> divide-y divide-outline-variant bg-surface-container-lowest">
                <% if published_lessons.empty? %>
                  <p class="px-4 py-3 text-sm text-on-surface-variant">レッスンを準備中です。</p>
                <% else %>
                  <% published_lessons.each do |lesson| %>
                    <%= render "courses/lesson_row", lesson: lesson,
                          completed: @completed_lesson_ids.include?(lesson.id) %>
                  <% end %>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>
    </section>
  </div>

  <%# サブスク訴求カード。ヒーロー帯へ食い込ませ、スクロール時は追従させる。 %>
  <div class="hidden lg:block">
    <div class="sticky top-4 lg:-mt-28">
      <%= render "courses/subscription_card",
            course: @course, sections_count: @sections.size,
            total_lessons: @total_lessons, completed_lessons: @completed_lessons,
            first_lesson: first_lesson, pct: pct, cover_color_var: cover_color_var %>
    </div>
  </div>
</div>
