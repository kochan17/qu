<%# レッスン行 — Udemy 風。完了時はテキストを variant に落とし、右端に修了バッジ。
    locals: lesson, completed %>

<%
  icon_name = case lesson.content_type
              when "video" then "play_circle"
              when "audio" then "headphones"
              when "quiz"  then "quiz"
              else              "article"
              end

  minutes = lesson.duration_seconds.present? && lesson.duration_seconds > 0 ?
    "#{(lesson.duration_seconds / 60.0).ceil}分" : nil
%>

<%= link_to lesson_path(lesson),
      class: "group flex items-start gap-3 px-4 py-3 transition-colors hover:bg-surface-container-low" do %>

  <%# コンテンツ種別アイコン（完了時は check に差し替え）%>
  <div class="shrink-0 pt-0.5">
    <% if completed %>
      <%= icon("check_circle", filled: true, css: "text-xl text-secondary") %>
    <% else %>
      <%= icon(icon_name, css: "text-xl text-on-surface-variant") %>
    <% end %>
  </div>

  <%# 本文 %>
  <div class="min-w-0 flex-1">
    <p class="font-body text-sm leading-snug line-clamp-2 <%= completed ? "text-on-surface-variant" : "text-on-surface" %>">
      <%= lesson.title %>
    </p>

    <% if lesson.intro.present? %>
      <p class="mt-0.5 font-body text-xs leading-relaxed text-outline line-clamp-1"><%= lesson.intro %></p>
    <% end %>
  </div>

  <%# 右端: 分数 or 修了ラベル %>
  <div class="shrink-0 ml-2 flex items-center gap-2">
    <% if minutes %>
      <span class="font-label text-xs text-outline tabular-nums"><%= minutes %></span>
    <% end %>
    <% if completed %>
      <span class="font-label text-xs font-semibold text-secondary">修了</span>
    <% else %>
      <%= icon("chevron_right", css: "text-lg text-outline transition-transform group-hover:translate-x-0.5") %>
    <% end %>
  </div>

<% end %>
