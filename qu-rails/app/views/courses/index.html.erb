<%# コース一覧 — Udemy カタログ風。 %>
<% content_for :title, @certification ? "#{@certification.name} — コース一覧" : "学習" %>

<div class="mx-auto max-w-7xl px-4 py-10 md:px-6 md:py-14 space-y-10">

  <header class="border-b border-outline-variant pb-6">
    <% if @certification %>
      <div class="flex flex-wrap items-end justify-between gap-4">
        <div>
          <p class="mb-1 font-label text-xs uppercase tracking-widest text-on-surface-variant">
            <%= @certification.name %>
          </p>
          <h1 class="font-headline text-2xl font-bold text-on-surface md:text-3xl">コース一覧</h1>
          <p class="mt-2 text-sm text-on-surface-variant">月額プランで全コースが学び放題です。</p>
        </div>
        <%= link_to settings_path, class: "btn btn-outline btn-sm" do %>
          <%= icon("swap_horiz", css: "text-base") %>
          資格を選ぶ
        <% end %>
      </div>
    <% else %>
      <h1 class="font-headline text-2xl font-bold text-on-surface md:text-3xl">学習</h1>
    <% end %>
  </header>

  <% if @certification.nil? %>
    <div class="card space-y-4 px-8 py-16 text-center">
      <%= icon("school", css: "text-4xl text-on-surface-variant") %>
      <p class="font-headline text-lg font-bold text-on-surface">学習する資格が設定されていません</p>
      <p class="text-sm text-on-surface-variant">設定画面から資格を選んで学習をスタートしよう。</p>
      <%= link_to "資格を選ぶ", settings_path, class: "btn btn-primary btn-sm mt-2 inline-flex" %>
    </div>

  <% elsif @courses.empty? %>
    <div class="card space-y-4 px-8 py-16 text-center">
      <%= icon("auto_stories", css: "text-4xl text-on-surface-variant") %>
      <p class="font-headline text-lg font-bold text-on-surface">コンテンツを準備中です</p>
      <p class="text-sm text-on-surface-variant">もうしばらくお待ちください。</p>
    </div>

  <% else %>
    <div class="grid grid-cols-2 gap-5 sm:grid-cols-3 lg:grid-cols-4">
      <% @courses.each do |course| %>
        <%= render "courses/course_card",
              course:    course,
              cert_slug: @certification.slug,
              progress:  @course_progress[course.id] || { total: 0, completed: 0 } %>
      <% end %>
    </div>
  <% end %>

</div>
